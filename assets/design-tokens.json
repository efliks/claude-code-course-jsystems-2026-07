{
  "$meta": {
    "source": "https://www.play.pl",
    "extractedAt": "2026-07-14",
    "method": "computed styles via Playwright on the live homepage"
  },
  "colors": {
    "brand": {
      "primary": "#6C43BF",
      "primaryDark": "#48227C",
      "logoBackground": "#2D0066",
      "accent": "#E6144B",
      "highlight": "#FFF200"
    },
    "background": {
      "default": "#FFFFFF",
      "light": "#FAFAFA",
      "subtle": "#F5F5F5",
      "overlay": "rgba(255, 255, 255, 0.9)"
    },
    "text": {
      "primary": "#1F1F1F",
      "emphasis": "#26232C",
      "secondary": "#707070",
      "muted": "#999999",
      "onDark": "#FFFFFF",
      "brand": "#6C43BF"
    },
    "link": {
      "default": "#266DD9",
      "alternative": "#0563C1"
    },
    "border": {
      "default": "#D6D6D6",
      "strong": "#AAAAAA"
    }
  },
  "typography": {
    "fontFamily": {
      "primary": "Manrope, Arial, sans-serif"
    },
    "fontFaces": [
      { "family": "Manrope", "weight": 500, "src": "https://media-play.pl/binaries/web/fonts/Manrope-Regular.woff2" },
      { "family": "Manrope", "weight": 600, "src": "https://media-play.pl/binaries/web/fonts/Manrope-SemiBold.woff2" },
      { "family": "Manrope", "weight": 700, "src": "https://media-play.pl/binaries/web/fonts/Manrope-Bold.woff2" }
    ],
    "fontWeights": { "regular": 500, "semibold": 600, "bold": 700 },
    "fontSize": {
      "xs": "10.5px",
      "sm": "12.25px",
      "base": "14px",
      "md": "16px",
      "lg": "21px",
      "xl": "28px",
      "xxl": "40px"
    },
    "lineHeight": { "tight": "1.3", "base": "1.5", "relaxed": "1.6" }
  },
  "spacing": {
    "comment": "Play uses a 3.5px base rhythm (0.25rem at the site's 14px root scale)",
    "1": "3.5px",
    "2": "7px",
    "3": "10.5px",
    "4": "14px",
    "5": "17.5px",
    "6": "21px",
    "8": "28px",
    "12": "42px"
  },
  "borderRadius": {
    "xs": "2px",
    "sm": "3.5px",
    "base": "7px",
    "md": "10.5px",
    "lg": "14px",
    "circle": "50%"
  },
  "components": {
    "button": {
      "primary": {
        "backgroundColor": "#6C43BF",
        "color": "#FFFFFF",
        "padding": "0 21px",
        "borderRadius": "7px",
        "fontSize": "14px",
        "fontWeight": 500,
        "border": "none"
      },
      "secondary": {
        "backgroundColor": "#FFFFFF",
        "color": "#6C43BF",
        "padding": "0 21px",
        "borderRadius": "7px",
        "fontSize": "14px",
        "fontWeight": 500,
        "border": "none"
      },
      "iconCircle": {
        "backgroundColor": "#FFFFFF",
        "color": "#000000",
        "borderRadius": "50%",
        "border": "0.8px solid #D6D6D6"
      }
    },
    "header": {
      "backgroundColor": "transparent",
      "color": "#1F1F1F",
      "fontSize": "14px"
    },
    "nav": {
      "color": "#1F1F1F",
      "activeColor": "#6C43BF",
      "fontSize": "10.5px",
      "fontWeight": 500,
      "activeFontWeight": 700,
      "textTransform": "none"
    },
    "body": {
      "backgroundColor": "#FFFFFF",
      "color": "#1F1F1F",
      "fontSize": "14px",
      "fontWeight": 500,
      "lineHeight": "21px"
    },
    "headings": {
      "h2": { "fontSize": "40px", "fontWeight": 500, "lineHeight": "60px", "color": "#1F1F1F" },
      "h3": { "fontSize": "21px", "fontWeight": 500, "lineHeight": "27.3px", "color": "#1F1F1F" }
    }
  }
}
